DB_HOST=localhost
DB_PORT=5432
DB_NAME=app_db
DB_USER=app_user
DB_PASSWORD=app_password
TEST_DB_NAME=test_db
# Server-side HMAC secret used to hash presented agent API keys before
# lookup against agent_api_credentials.api_key_hash.
# Local/dev value only; production should inject this from a secret store.
AGENT_CREDENTIAL_HASH_SECRET=local-dev-agent-credential-hash-secret
